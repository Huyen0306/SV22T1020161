@using SV22T1020161.Models.Catalog
@using SV22T1020161.Models.Common
@model PagedResult<Product>
@{
    Layout = null;
}
<div class="js-paged-meta d-none" data-row-count="@Model.RowCount" aria-hidden="true"></div>

@if (Model.DataItems.Count == 0)
{
    <div class="md-empty-state">
        <div class="md-empty-icon">
            <i class="bi bi-search"></i>
        </div>
        <h3 style="font-size:1.25rem;font-weight:700;color:var(--md-on-surface);">Không tìm thấy kết quả nào</h3>
        <p class="text-muted-md mt-2" style="max-width:360px;">Rất tiếc, chúng tôi không tìm thấy mặt hàng nào phù hợp với bộ lọc và từ khóa của bạn.</p>
        <button onclick="resetFilter()" class="md-btn md-btn-primary mt-6">
            <i class="bi bi-arrow-counterclockwise"></i> Xóa bộ lọc và thử lại
        </button>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var p in Model.DataItems)
        {
            <div class="col-6 col-md-4 col-xl-3">
                <div class="md-product-card">
                    <a href="/Product/Detail/@p.ProductID" class="product-img-wrap">
                        @if (string.IsNullOrEmpty(p.Photo))
                        {
                            <img src="https://placehold.co/400x400/e8def8/6750a4?text=No+Photo"
                                 alt="@p.ProductName" />
                        }
                        else if (p.Photo.StartsWith("http"))
                        {
                            <img src="@p.Photo" alt="@p.ProductName" />
                        }
                        else
                        {
                            <img src="~/images/products/@p.Photo" alt="@p.ProductName" />
                        }

                        @if (!p.IsSelling)
                        {
                            <div class="sold-out-overlay">
                                <span class="sold-out-badge">Ngừng bán</span>
                            </div>
                        }

                        <span class="unit-badge">@p.Unit</span>
                    </a>

                    <div class="product-body">
                        <a href="/Product/Detail/@p.ProductID" class="product-name">@p.ProductName</a>
                        <div class="d-flex align-items-center justify-content-between mt-2">
                            <p class="product-price mb-0">
                                @p.Price.ToString("N0") <small>đ</small>
                            </p>
                        </div>

                        @if (p.IsSelling == true)
                        {
                            <button type="button" onclick="addToCart(@p.ProductID)"
                                    class="md-btn md-btn-primary w-100 mt-3"
                                    style="font-size:0.8125rem;padding:8px 16px;">
                                <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (Model.PageCount > 1)
{
    int windowSize = 7;
    int half = windowSize / 2;
    int winStart = Model.Page - half;
    int winEnd = Model.Page + half;
    if (winStart < 1)
    {
        winStart = 1;
        winEnd = Math.Min(windowSize, Model.PageCount);
    }
    if (winEnd > Model.PageCount)
    {
        winEnd = Model.PageCount;
        winStart = Math.Max(1, Model.PageCount - windowSize + 1);
    }

    bool showLead1 = winStart > 1;
    bool showLeadEllipsis = winStart > 2;
    bool showTrailEllipsis = winEnd < Model.PageCount - 1;
    bool showLast = winEnd < Model.PageCount;

    <div class="d-flex justify-content-center mt-5 pt-4" style="border-top:1px solid var(--md-outline-variant);">
        <ul class="md-pagination md-pagination--fixed mb-0 justify-content-center" style="min-height:44px;">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : null)">
                @if (Model.Page > 1)
                {
                    <a href="javascript:void(0)" onclick="doSearch(@(Model.Page - 1))" class="page-link" aria-label="Trang trước">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                }
                else
                {
                    <span class="page-link" aria-hidden="true"><i class="bi bi-chevron-left"></i></span>
                }
            </li>

            <li class="page-item md-page-slot @(showLead1 ? null : "md-page-slot--empty")">
                @if (showLead1)
                {
                    <a href="javascript:void(0)" onclick="doSearch(1)" class="page-link">1</a>
                }
                else
                {
                    <span class="page-link" aria-hidden="true">&nbsp;</span>
                }
            </li>
            <li class="page-item md-page-slot @(showLeadEllipsis ? "disabled" : "md-page-slot--empty")">
                @if (showLeadEllipsis)
                {
                    <span class="page-link">&hellip;</span>
                }
                else
                {
                    <span class="page-link" aria-hidden="true">&nbsp;</span>
                }
            </li>

            @for (int i = 0; i < windowSize; i++)
            {
                int p = winStart + i;
                if (p <= winEnd && p <= Model.PageCount && p >= 1)
                {
                    if (p == Model.Page)
                    {
                        <li class="page-item active"><span class="page-link">@p</span></li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a href="javascript:void(0)" onclick="doSearch(@p)" class="page-link">@p</a>
                        </li>
                    }
                }
                else
                {
                    <li class="page-item md-page-slot md-page-slot--empty">
                        <span class="page-link" aria-hidden="true">&nbsp;</span>
                    </li>
                }
            }

            <li class="page-item md-page-slot @(showTrailEllipsis ? "disabled" : "md-page-slot--empty")">
                @if (showTrailEllipsis)
                {
                    <span class="page-link">&hellip;</span>
                }
                else
                {
                    <span class="page-link" aria-hidden="true">&nbsp;</span>
                }
            </li>
            <li class="page-item md-page-slot @(showLast ? null : "md-page-slot--empty")">
                @if (showLast)
                {
                    <a href="javascript:void(0)" onclick="doSearch(@Model.PageCount)" class="page-link">@Model.PageCount</a>
                }
                else
                {
                    <span class="page-link" aria-hidden="true">&nbsp;</span>
                }
            </li>

            <li class="page-item @(Model.Page >= Model.PageCount ? "disabled" : null)">
                @if (Model.Page < Model.PageCount)
                {
                    <a href="javascript:void(0)" onclick="doSearch(@(Model.Page + 1))" class="page-link" aria-label="Trang sau">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                }
                else
                {
                    <span class="page-link" aria-hidden="true"><i class="bi bi-chevron-right"></i></span>
                }
            </li>
        </ul>
    </div>
}
