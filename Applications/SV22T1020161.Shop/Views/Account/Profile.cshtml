@model SV22T1020161.Models.Partner.Customer
@{
    ViewData["Title"] = "QuášĢn lÃ― tÃ i khoášĢn";
}

<div class="animate-in">
    <!-- Page Header -->
    <div class="page-header mb-5">
        <div>
            <h1 style="font-size:1.75rem;font-weight:800;">TÃ i khoášĢn cáŧ§a tÃīi</h1>
            <p class="text-muted-md mb-0" style="font-size:0.875rem;">QuášĢn lÃ― thÃīng tin cÃĄ nhÃĒn vÃ  bášĢo máš­t</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Sidebar Navigation -->
        <div class="col-lg-3">
            <div class="md-profile-nav" style="background: #ffffff !important; border: none !important; border-radius: 16px; overflow: hidden; box-shadow: none !important; color: var(--md-on-surface);">
                <div class="nav-header" style="padding: 24px; border-bottom: 1px solid var(--md-outline-variant); background: #ffffff !important;">
                    <div style="width:56px;height:56px;border-radius:var(--md-radius-full);background:linear-gradient(135deg,var(--md-primary),var(--md-tertiary));display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:1.25rem;flex-shrink:0;margin-bottom:12px;">
                        @(Model?.CustomerName?.Length > 0 ? Model.CustomerName.Substring(0, 1).ToUpper() : "U")
                    </div>
                    <div>
                        <h4 style="font-weight:700;font-size:1rem;margin-bottom:4px;color:var(--md-on-surface);">@(Model?.CustomerName ?? "NgÆ°áŧi dÃđng")</h4>
                        <p style="font-size:0.875rem;color:var(--md-on-surface-variant);margin:0;">@(Model?.Email)</p>
                    </div>
                </div>
                <nav class="nav flex-column" style="padding: 12px;">
                    <style>
                        .profile-nav-btn {
                            display: flex;
                            align-items: center;
                            gap: 12px;
                            padding: 12px 16px;
                            border-radius: 12px;
                            color: var(--md-on-surface-variant);
                            font-weight: 500;
                            text-decoration: none;
                            transition: all 0.2s ease;
                            margin-bottom: 4px;
                        }
                        .profile-nav-btn:hover {
                            background: var(--md-surface-container-low);
                            color: var(--md-primary);
                        }
                        .profile-nav-btn i {
                            font-size: 1.25rem;
                        }
                        .profile-nav-btn.logout-btn:hover {
                            background: var(--md-error-container);
                            color: var(--md-error);
                        }
                    </style>
                    <a href="#info" class="profile-nav-btn">
                        <i class="bi bi-person"></i> ThÃīng tin cÃĄ nhÃĒn
                    </a>
                    <a href="#password" class="profile-nav-btn">
                        <i class="bi bi-shield-lock"></i> Äáŧi máš­t khášĐu
                    </a>
                    <div style="height:1px;background:var(--md-outline-variant);margin:12px 16px;"></div>
                    <a href="~/Order/History" class="profile-nav-btn">
                        <i class="bi bi-receipt"></i> ÄÆĄn hÃ ng cáŧ§a tÃīi
                    </a>
                    <a href="~/Account/Logout" class="profile-nav-btn logout-btn" style="color:var(--md-error);">
                        <i class="bi bi-box-arrow-right"></i> ÄÄng xuášĨt
                    </a>
                </nav>
            </div>
        </div>

        <!-- Main Content Area -->
        <div class="col-lg-9 d-flex flex-column gap-4">

            <!-- Profile Info Section -->
            <section id="info" class="md-card">
                <div class="md-card-header">
                    <div class="md-card-icon" style="background:var(--md-primary-container);color:var(--md-primary);">
                        <i class="bi bi-person"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h3 style="font-size:1rem;font-weight:700;margin:0;">ThÃīng tin cÃĄ nhÃĒn</h3>
                        <p class="text-muted-md mb-0" style="font-size:0.8125rem;">Cáš­p nháš­t thÃīng tin chi tiášŋt vÃ  Äáŧa cháŧ liÃŠn lášĄc cáŧ§a bášĄn.</p>
                    </div>
                    <button type="submit" form="profileForm" class="md-btn md-btn-primary">
                        <i class="bi bi-check2-circle"></i> LÆ°u thay Äáŧi
                    </button>
                </div>
                <div class="md-card-body">
                    <form id="profileForm" action="~/Account/UpdateProfile" method="post" class="d-flex flex-column gap-4">
                        <div class="row g-3">
                            <!-- Full Name -->
                            <div class="col-md-6">
                                <div class="md-form-group mb-0">
                                    <label class="md-label">
                                        <span>Háŧ vÃ  tÃŠn</span>
                                        <span class="md-error-message" id="error-CustomerName"></span>
                                    </label>
                                    <input type="text" id="CustomerName" name="CustomerName" value="@Model?.CustomerName" class="md-input" />
                                </div>
                            </div>
                            <!-- Email (Read-only) -->
                            <div class="col-md-6">
                                <div class="md-form-group mb-0">
                                    <label class="md-label">Email (KhÃīng tháŧ thay Äáŧi)</label>
                                    <input type="email" value="@Model?.Email" disabled class="md-input" style="background:var(--md-surface-variant);cursor:not-allowed;" />
                                </div>
                            </div>
                            <!-- Phone -->
                            <div class="col-md-6">
                                <div class="md-form-group mb-0">
                                    <label class="md-label">
                                        <span>Sáŧ Äiáŧn thoášĄi</span>
                                        <span class="md-error-message" id="error-Phone"></span>
                                    </label>
                                    <input type="tel" id="Phone" name="Phone" value="@Model?.Phone" class="md-input" />
                                </div>
                            </div>
                            <!-- Province -->
                            <div class="col-md-6">
                                <div class="md-form-group mb-0">
                                    <label class="md-label">Táŧnh / ThÃ nh pháŧ</label>
                                    <select name="Province" class="md-select">
                                        <option value="">-- Cháŧn táŧnh/thÃ nh --</option>
                                        @foreach (var province in await SV22T1020161.BusinessLayers.DictionaryDataService.ListProvincesAsync())
                                        {
                                            <option value="@province.ProvinceName" selected="@(province.ProvinceName == Model?.Province)">
                                                @province.ProvinceName
                                            </option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <!-- Address -->
                        <div>
                            <div class="md-form-group mb-0">
                                <label class="md-label">Äáŧa cháŧ cáŧĨ tháŧ</label>
                                <textarea name="Address" rows="2" class="md-input" style="resize:none;">@Model?.Address</textarea>
                            </div>
                        </div>
                    </form>
                </div>
            </section>

            <!-- Change Password Section -->
            <section id="password" class="md-card">
                <div class="md-card-header">
                    <div class="md-card-icon" style="background:var(--md-secondary-container);color:var(--md-secondary);">
                        <i class="bi bi-shield-lock"></i>
                    </div>
                    <div>
                        <h3 style="font-size:1rem;font-weight:700;margin:0;">Äáŧi máš­t khášĐu</h3>
                        <p class="text-muted-md mb-0" style="font-size:0.8125rem;">NÃŠn sáŧ­ dáŧĨng máš­t khášĐu mášĄnh Äáŧ bášĢo váŧ tÃ i khoášĢn.</p>
                    </div>
                </div>
                <div class="md-card-body">
                    <form id="changePasswordForm" action="~/Account/ChangePassword" method="post" class="d-flex flex-column gap-4" style="max-width:480px;">
                        <div class="md-form-group mb-0">
                            <label class="md-label">
                                <span>Máš­t khášĐu hiáŧn tášĄi</span>
                                <span class="md-error-message" id="error-oldPassword">
                                    @if (TempData["ErrorMessage"]?.ToString() == "Máš­t khášĐu cÅĐ khÃīng chÃ­nh xÃĄc.") { @TempData["ErrorMessage"] }
                                </span>
                            </label>
                            <div class="md-input-wrap">
                                <i class="bi bi-lock input-icon"></i>
                                <input type="password" id="oldPassword" name="oldPassword" placeholder="Nháš­p máš­t khášĐu hiáŧn tášĄi" required class="md-input @(TempData["ErrorMessage"]?.ToString() == "Máš­t khášĐu cÅĐ khÃīng chÃ­nh xÃĄc." ? "is-invalid" : "")" style="padding-right: 44px;" />
                                <button type="button" class="password-toggle" onclick="togglePassword(this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="md-form-group mb-0">
                            <label class="md-label">
                                <span>Máš­t khášĐu máŧi</span>
                                <span class="md-error-message" id="error-newPassword">
                                    @if (TempData["ErrorMessage"]?.ToString() == "Máš­t khášĐu máŧi phášĢi cÃģ Ã­t nhášĨt 6 kÃ― táŧą.") { @TempData["ErrorMessage"] }
                                </span>
                            </label>
                            <div class="md-input-wrap">
                                <i class="bi bi-key input-icon"></i>
                                <input type="password" id="newPassword" name="newPassword" placeholder="Táŧi thiáŧu 6 kÃ― táŧą" required minlength="6" class="md-input @(TempData["ErrorMessage"]?.ToString() == "Máš­t khášĐu máŧi phášĢi cÃģ Ã­t nhášĨt 6 kÃ― táŧą." ? "is-invalid" : "")" style="padding-right: 44px;" />
                                <button type="button" class="password-toggle" onclick="togglePassword(this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="md-form-group mb-0">
                            <label class="md-label">
                                <span>XÃĄc nháš­n máš­t khášĐu máŧi</span>
                                <span class="md-error-message" id="error-confirmPassword">
                                    @if (TempData["ErrorMessage"]?.ToString() == "Máš­t khášĐu xÃĄc nháš­n khÃīng kháŧp.") { @TempData["ErrorMessage"] }
                                </span>
                            </label>
                            <div class="md-input-wrap">
                                <i class="bi bi-shield-check input-icon"></i>
                                <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Nháš­p lášĄi máš­t khášĐu máŧi" required class="md-input @(TempData["ErrorMessage"]?.ToString() == "Máš­t khášĐu xÃĄc nháš­n khÃīng kháŧp." ? "is-invalid" : "")" style="padding-right: 44px;" />
                                <button type="button" class="password-toggle" onclick="togglePassword(this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div>
                            <button type="submit" class="md-btn md-btn-primary">
                                <i class="bi bi-key"></i> Cáš­p nháš­t máš­t khášĐu
                            </button>
                        </div>
                    </form>
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.md-profile-nav .nav-item[href^="#"]').forEach(function(link) {
            link.addEventListener('click', function(e) {
                var target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    e.preventDefault();
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });

        function togglePassword(btn) {
            const input = btn.parentElement.querySelector('input');
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }

        const cpForm = document.getElementById('changePasswordForm');
        const pfForm = document.getElementById('profileForm');

        function showError(formId, id, msg) {
            const errSpan = document.getElementById('error-' + id);
            const input = document.getElementById(id);
            if (errSpan) errSpan.textContent = msg;
            if (input) input.classList.add('is-invalid');
        }
        function clearErrors(formId, fields) {
            fields.forEach(id => {
                const errSpan = document.getElementById('error-' + id);
                const input = document.getElementById(id);
                if (errSpan) errSpan.textContent = '';
                if (input) input.classList.remove('is-invalid');
            });
        }
        function showToast(msg, type = 'success') {
            const toast = document.createElement('div');
            toast.className = 'toast-container';
            const icon = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill';
            const alertClass = type === 'success' ? 'md-alert-success' : 'md-alert-error';
            toast.innerHTML = `<div class="md-alert ${alertClass}" style="position:fixed;bottom:24px;right:24px;z-index:9999;min-width:280px;animation:fadeInUp 0.3s ease"><i class="bi ${icon}"></i><div>${msg}</div></div>`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        if (pfForm) {
            pfForm.addEventListener('submit', function(e) {
                e.preventDefault();
                const fields = ['CustomerName', 'Phone'];
                clearErrors('profileForm', fields);
                const data = new FormData(pfForm);
                const name = data.get('CustomerName');
                const phone = data.get('Phone');
                
                if (!name) {
                    showError('profileForm', 'CustomerName', 'Háŧ tÃŠn khÃīng ÄÆ°áŧĢc Äáŧ tráŧng.');
                    return;
                }
                // Regex háŧ tráŧĢ Tiášŋng Viáŧt Äáš§y Äáŧ§ vÃ  dášĨu cÃĄch
                const nameRegex = /^[A-Za-zÃÃÃÃÃÃÃÃÃÃÃÃÃÃÃÄÄÄĻÅĻÆ Ã ÃĄÃĒÃĢÃĻÃĐÃŠÃŽÃ­ÃēÃģÃīÃĩÃđÃšÄÄÄĐÅĐÆĄÆŊÄÃÃÃÆ ÆŊÆ°ÄÃĒÃŠÃīÆĄÆ°áš -áŧđ ]+$/;
                if (!nameRegex.test(name)) {
                    showError('profileForm', 'CustomerName', 'Háŧ tÃŠn cháŧ ÄÆ°áŧĢc cháŧĐa cháŧŊ cÃĄi vÃ  khoášĢng trášŊng.');
                    return;
                }
                if (name.trim().length < 2) {
                    showError('profileForm', 'CustomerName', 'Háŧ tÃŠn phášĢi táŧŦ 2 kÃ― táŧą.');
                    return;
                }

                if (phone) {
                    const phoneRegex = /^[0-9]{10,11}$/;
                    if (!phoneRegex.test(phone)) {
                        showError('profileForm', 'Phone', 'Sáŧ Äiáŧn thoášĄi phášĢi táŧŦ 10-11 cháŧŊ sáŧ.');
                        return;
                    }
                }

                fetch(pfForm.action, {
                    method: 'POST',
                    body: new URLSearchParams(data)
                })
                .then(res => res.json())
                .then(res => {
                    if (res.success) {
                        showToast(res.message);
                    } else {
                        if (res.field) showError('profileForm', res.field, res.message);
                        else showToast(res.message, 'error');
                    }
                })
                .catch(() => showToast('Láŧi kášŋt náŧi server.', 'error'));
            });
        }

        if (cpForm) {
            cpForm.addEventListener('submit', function (e) {
                e.preventDefault();
                const fields = ['oldPassword', 'newPassword', 'confirmPassword'];
                clearErrors('changePasswordForm', fields);

                const data = new FormData(cpForm);
                const oldPass = data.get('oldPassword');
                const newPass = data.get('newPassword');
                const confirmPass = data.get('confirmPassword');

                let hasError = false;
                if (!oldPass) { showError('changePasswordForm', 'oldPassword', 'Vui lÃēng nháš­p máš­t khášĐu cÅĐ.'); hasError = true; }
                if (newPass.length < 6) { showError('changePasswordForm', 'newPassword', 'Máš­t khášĐu máŧi phášĢi táŧŦ 6 kÃ― táŧą.'); hasError = true; }
                else if (newPass !== confirmPass) { showError('changePasswordForm', 'confirmPassword', 'Máš­t khášĐu xÃĄc nháš­n khÃīng kháŧp.'); hasError = true; }

                if (hasError) return;

                fetch(cpForm.action, {
                    method: 'POST',
                    body: new URLSearchParams(data)
                })
                .then(res => res.json())
                .then(res => {
                    if (res.success) {
                        showToast(res.message);
                        cpForm.reset();
                    } else {
                        if (res.field) showError('changePasswordForm', res.field, res.message);
                        else showToast(res.message, 'error');
                    }
                })
                .catch(() => showToast('Láŧi kášŋt náŧi server.', 'error'));
            }, true);
        }
    </script>
    <style>
        .password-toggle {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--md-outline);
            cursor: pointer;
            padding: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: color 0.15s;
        }
        .password-toggle:hover {
            color: var(--md-primary);
        }
        .md-input-wrap .input-icon {
            left: 14px;
            z-index: 2;
        }
        .md-input-wrap .md-input {
            padding-left: 44px;
        }
    </style>
}
