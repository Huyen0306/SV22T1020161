@using SV22T1020161.Admin
@using SV22T1020161.Models.Constants
@{
    var employeeName = Context.Session.GetString("EmployeeName") ?? "Admin";
    var employeeEmail = Context.Session.GetString("EmployeeEmail") ?? "";
    var employeeId = Context.Session.GetInt32("EmployeeID");
    var roleNames = Context.Session.GetString("EmployeeRoles") ?? "";
    var roles = string.IsNullOrWhiteSpace(roleNames)
        ? new List<string>()
        : roleNames.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    var permissions = new List<string>();
    foreach (var role in roles)
    {
        var perms = Roles.GetPermissions(role);
        foreach (var perm in perms)
        {
            if (!permissions.Contains(perm))
                permissions.Add(perm);
        }
    }
    bool HasPerm(string p) => permissions.Contains(p);

    // Lấy ảnh từ Claim "Photo"
    var employeePhoto = User.FindFirst("Photo")?.Value ?? "";
    var hasPhoto = !string.IsNullOrWhiteSpace(employeePhoto)
                   && employeePhoto != "nophoto.png"
                   && employeePhoto != "no_photo.png";
    var photoUrl = hasPhoto ? Url.Content($"~/images/employees/{employeePhoto}") : "";

    // Chữ cái đầu tiên của tên để hiển thị khi không có ảnh
    var firstLetter = (employeeName.Length > 0 ? employeeName[0].ToString() : "?").ToUpper();
}

<style>
    .user-avatar-initials {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        font-weight: 700;
        box-shadow: 0 2px 8px rgba(102,126,234,0.4);
        user-select: none;
        flex-shrink: 0;
    }
    .user-avatar-initials-lg {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        font-weight: 700;
        box-shadow: 0 4px 16px rgba(102,126,234,0.5);
        margin: 0 auto;
        user-select: none;
    }
</style>

<nav class="app-header navbar navbar-expand bg-body-secondary">
    <div class="container-fluid">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                    <i class="bi bi-list"></i>
                </a>
            </li>
            @if (HasPerm(Permissions.DashboardView))
            {
                <li class="nav-item d-none d-md-block"><a href="~/" class="nav-link">Trang chủ</a></li>
            }
        </ul>
        <ul class="navbar-nav ms-auto">
            <li class="nav-item dropdown user-menu">
                <a href="#" class="nav-link dropdown-toggle d-flex align-items-center gap-2" data-bs-toggle="dropdown">
                    @if (hasPhoto)
                    {
                        <img src="@photoUrl"
                             class="user-image rounded-circle shadow"
                             style="width:40px;height:40px;object-fit:cover;"
                             alt="@employeeName" />
                    }
                    else
                    {
                        <div class="user-avatar-initials">@firstLetter</div>
                    }
                    <span class="d-none d-md-inline">@employeeName</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-end">
                    <li class="user-header text-bg-primary d-flex flex-column align-items-center py-3">
                        @if (hasPhoto)
                        {
                            <img src="@photoUrl"
                                 class="rounded-circle shadow"
                                 style="width:90px;height:90px;object-fit:cover;"
                                 alt="@employeeName" />
                        }
                        else
                        {
                            <div class="user-avatar-initials-lg">@firstLetter</div>
                        }
                        <p class="mt-2 mb-0 text-center">
                            @employeeName
                            <small class="d-block">@employeeEmail</small>
                        </p>
                    </li>
                    <li class="user-footer">
                        <a href="~/Account/Profile" class="btn btn-default btn-flat">Hồ sơ</a>
                        <a href="~/Account/Logout" class="btn btn-danger btn-flat float-end">
                            <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
                        </a>
                    </li>
                </ul>
            </li>
        </ul>
    </div>
</nav>
