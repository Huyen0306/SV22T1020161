## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This file is specific to .NET Core / .NET projects.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
Log/
Logs/

# Visual Studio 2015/2017/2019/2022 cache files
.vs/
# Uncomment if you use a linting tool like StyleCop
# *.SourceAnalysisLog
# *.StyleCop

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core Data Protection Keys
# (These should NOT be committed as they contain sensitive encryption keys)
DataProtection-Keys/
DataProtectionKeys/
keys/

# Microsoft Azure
*.publishsettings

# Built-in help and documentation
_site/

# Web Tools (Node, Bower, etc.)
node_modules/
bower_components/

# Files generated by the OS
.DS_Store
Thumbs.db

# JetBrains IDEs (Rider, Resharper)
.idea/
*.sln.iml

# Model specific (Antigravity/Gemini)
.gemini/
.antigravity/
brain/
artifacts/
tmp/

# App settings (Optional: keep if they contain only non-sensitive defaults)
# appsettings.Development.json
# appsettings.Local.json
